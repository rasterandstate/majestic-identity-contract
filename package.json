{
  "name": "majestic-identity-contract",
  "version": "1.0.0",
  "description": "Deterministic identity logic for Majestic: edition hash, region/packaging normalization, fingerprint policy",
  "type": "module",
  "main": "src/index.ts",
  "packageManager": "pnpm@10.30.3",
  "exports": {
    ".": "./src/index.ts",
    "./editionHash": "./src/editionHash.ts",
    "./normalization": "./src/normalization.ts",
    "./fingerprintPolicy": "./src/fingerprintPolicy.ts"
  },
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:no-coverage": "vitest run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
